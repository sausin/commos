{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://commos.dev/schemas/events/UserSuspended.schema.json",
  "title": "UserSuspended",
  "description": "CommOS canonical event 'UserSuspended' (Volume 5). Envelope + typed data payload.",
  "allOf": [
    {
      "$ref": "https://commos.dev/schemas/envelope.schema.json"
    }
  ],
  "properties": {
    "type": {
      "const": "UserSuspended"
    },
    "data": {
      "type": "object",
      "properties": {
        "user_id": {
          "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/Uuid"
        },
        "reason": {
          "type": "string"
        }
      },
      "required": [
