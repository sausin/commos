{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://commos.dev/schemas/events/DeviceApproved.schema.json",
  "title": "DeviceApproved",
  "description": "CommOS canonical event 'DeviceApproved' (Volume 5). Envelope + typed data payload.",
  "allOf": [
    {
      "$ref": "https://commos.dev/schemas/envelope.schema.json"
    }
  ],
  "properties": {
    "type": {
      "const": "DeviceApproved"
    },
    "data": {
      "type": "object",
      "properties": {
        "device_id": {
          "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/Uuid"
        },
        "approved_by_user_id": {
          "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/Uuid"
        }
      },
      "required": [
        "device_id",
        "approved_by_user_id"
      ]
    }
  },
  "required": [
    "type",
    "data"
  ]
}
