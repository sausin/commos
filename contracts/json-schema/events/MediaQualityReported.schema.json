{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://commos.dev/schemas/events/MediaQualityReported.schema.json",
  "title": "MediaQualityReported",
  "description": "CommOS canonical event 'MediaQualityReported' (Volume 5). Envelope + typed data payload.",
  "allOf": [
    {
      "$ref": "https://commos.dev/schemas/envelope.schema.json"
    }
  ],
  "properties": {
    "type": {
      "const": "MediaQualityReported"
    },
    "data": {
      "type": "object",
      "properties": {
        "call_id": {
          "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/Uuid"
        },
        "stream_id": {
          "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/Uuid"
        },
        "mos": {
          "type": "number"
        },
        "jitter_ms": {
          "type": "number"
        },
        "packet_loss": {
          "type": "number"
        },
        "latency_ms": {
          "type": "number"
        }
      },
      "required": [
        "call_id",
        "mos"
      ]
    }
  },
  "required": [
    "type",
    "data"
  ]
}
