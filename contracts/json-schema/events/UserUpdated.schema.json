{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://commos.dev/schemas/events/UserUpdated.schema.json",
  "title": "UserUpdated",
  "description": "CommOS canonical event 'UserUpdated' (Volume 5). Envelope + typed data payload.",
  "allOf": [
    {
      "$ref": "https://commos.dev/schemas/envelope.schema.json"
    }
  ],
  "properties": {
    "type": {
      "const": "UserUpdated"
    },
    "data": {
      "type": "object",
      "properties": {
        "user_id": {
          "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/Uuid"
        },
        "changed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "user_id"
      ]
    }
  },
  "required": [
    "type",
    "data"
  ]
}
