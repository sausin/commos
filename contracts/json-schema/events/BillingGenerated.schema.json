{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://commos.dev/schemas/events/BillingGenerated.schema.json",
  "title": "BillingGenerated",
  "description": "CommOS canonical event 'BillingGenerated' (Volume 5). Envelope + typed data payload.",
  "allOf": [
    {
      "$ref": "https://commos.dev/schemas/envelope.schema.json"
    }
  ],
  "properties": {
    "type": {
      "const": "BillingGenerated"
    },
    "data": {
      "type": "object",
      "properties": {
        "cdr_id": {
          "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/Uuid"
        },
        "call_id": {
          "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/Uuid"
        },
        "user_id": {
          "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/Uuid"
        },
        "device_id": {
          "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/Uuid"
        },
        "billable_ms": {
          "type": "integer",
          "minimum": 0
        },
        "cost": {
          "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/Money"
        }
      },
      "required": [
        "cdr_id",
        "call_id",
        "billable_ms",
        "cost"
      ]
    }
  },
  "required": [
    "type",
    "data"
  ]
}
