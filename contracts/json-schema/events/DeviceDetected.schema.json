{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://commos.dev/schemas/events/DeviceDetected.schema.json",
  "title": "DeviceDetected",
  "description": "CommOS canonical event 'DeviceDetected' (Volume 5). Envelope + typed data payload.",
  "allOf": [
    {
      "$ref": "https://commos.dev/schemas/envelope.schema.json"
    }
  ],
  "properties": {
    "type": {
      "const": "DeviceDetected"
    },
    "data": {
      "type": "object",
      "properties": {
        "device_id": {
          "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/Uuid"
        },
        "vendor_key": {
          "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/OpenKey"
        },
        "model": {
          "type": "string"
        },
        "mac": {
          "type": "string",
          "pattern": "^[0-9a-f]{12}$"
        },
        "state": {
          "type": "string",
          "enum": [
            "DETECTED",
            "PENDING"
          ]
        }
      },
      "required": [
        "device_id",
        "vendor_key",
        "model",
        "state"
      ]
    }
  },
  "required": [
    "type",
    "data"
  ]
}
