{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://commos.dev/schemas/entities/Gateway.schema.json",
  "title": "Gateway",
  "description": "CommOS domain entity 'Gateway' (Volume 2).",
  "allOf": [
    {
      "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/EntityBase"
    }
  ],
  "properties": {
    "carrier_id": {
      "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/Uuid"
    },
    "kind": {
      "type": "string",
      "enum": [
        "SIP",
        "4G",
        "SIM_BANK"
      ]
    },
    "address": {
      "type": "string"
    },
    "health": {
      "type": "string",
      "enum": [
        "ONLINE",
        "OFFLINE"
      ]
    }
  },
  "required": [
    "carrier_id",
    "kind",
    "health"
  ]
}
