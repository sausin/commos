{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://commos.dev/schemas/entities/PresenceState.schema.json",
  "title": "PresenceState",
  "description": "CommOS domain entity 'PresenceState' (Volume 2).",
  "allOf": [
    {
      "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/EntityBase"
    }
  ],
  "properties": {
    "user_id": {
      "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/Uuid"
    },
    "status": {
      "type": "string",
      "enum": [
        "AVAILABLE",
        "BUSY",
        "AWAY",
        "DND",
        "OFFLINE",
        "ON_CALL"
      ]
    },
    "since": {
      "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/Timestamp"
    },
    "device_id": {
      "$ref": "https://commos.dev/schemas/common.schema.json#/$defs/Uuid"
    }
  },
  "required": [
    "user_id",
    "status"
  ]
}
